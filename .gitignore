# --- IDE / editor ---
.idea/
*.iml
.classpath
.project
.settings/
.vscode/

# --- Operating system ---
.DS_Store
Thumbs.db

# --- Logs and temporary files ---
*.log
npm-debug.log*
yarn-error.log*
.phpunit.result.cache

# --- Java / Maven / general build outputs ---
*.class
target/
*.ctxt
.mtj.tmp/
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# --- Laravel / PHP project (admink) ---
/admink/admink/vendor/
/admink/admink/node_modules/
/admink/admink/public/hot
/admink/admink/public/storage
/admink/admink/.env
/admink/admink/.env.backup

# Laravel runtime folders
/admink/admink/storage/app/*
!/admink/admink/storage/app/.gitignore
/admink/admink/storage/framework/*
!/admink/admink/storage/framework/.gitignore
/admink/admink/storage/logs/*
!/admink/admink/storage/logs/.gitignore
/admink/admink/bootstrap/cache/*
!/admink/admink/bootstrap/cache/.gitignore

# Laravel generated keys and public storage artifacts
/admink/admink/storage/*.key

# Keep the example file tracked
!/admink/admink/.env.example

# --- Nested env files anywhere in the repository ---
**/.env
**/.env.backup
!**/.env.example

# --- Generic Node / frontend artifacts ---
node_modules/
dist/
build/
coverage/
*.tsbuildinfo
